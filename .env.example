# ── Vaapty agente de pré-atendimento — exemplo (copie para .env e preencha) ──

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_UPDATER=gpt-4o
OPENAI_MODEL_RESPONDER=gpt-4o

# GoHighLevel (subconta Vaapty)
GHL_PIT_TOKEN=pit-...
GHL_LOCATION_ID=WNX3O0xMtrK6Ls7w4eTx
GHL_API_HOST=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# Custom Fields (contato) — IDs provisionados via scripts/provision_ghl.py
CF_STATUS_IA=CTDuCzrDKv7UYPI0bsZI
CF_LOCALIZACAO=UJ4QqrS7cvhMTCNg62cH
CF_VEICULO_MODELO=sN7JJpnI2OLZgO5KyBmN
CF_VEICULO_ANO=6v0vvVP2rpXqU4VFLJLo
CF_MOTIVO_VENDA=M1rBFceIDweMjnF1lhJd

# FAQ (Custom Value YAML, editável no CRM sem deploy)
CV_FAQ=CEEz12Rc4pr1rNvh4qYy

# Gate de atuação
TAG_AGENT_IA=agent-ia
TAG_AGENT_IA_ID=t3zzzAum0i1RAtFmKUy8

# Workflows de handoff (add-contact-to-workflow)
WORKFLOW_QUALIFICADO_ID=
WORKFLOW_DESQUALIFICADO_ID=

# Calendars negociadores (caminho fora-horário)
CALENDAR_ADRIANO=
CALENDAR_DARIO=
GHL_APPOINTMENT_DURATION_MIN=60

# Webhook (shared-secret no query ?secret=)
WEBHOOK_SECRET=troque-isto

# App
APP_HOST=0.0.0.0
APP_PORT=8080
APP_TIMEZONE=America/Sao_Paulo

# Postgres (estado/sessão por contactId)
DATABASE_URL=postgresql+asyncpg://vaapty:vaapty@localhost:5432/vaapty

# Tuning
FAQ_CACHE_TTL_SECONDS=300
CONVERSATION_HISTORY_LIMIT=100
RESPONDER_MAX_BUBBLES=4
RESPONDER_SLEEP_MIN=1.2
RESPONDER_SLEEP_MAX=2.8
HUMAN_REQUEST_THRESHOLD=3

# Raio de qualificação (cidades aceitas, csv minúsculo sem acento)
QUALIFY_CITIES=guarulhos,sao paulo,arujá,maua,santa isabel,itaquaquecetuba

# Logs / métricas
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
